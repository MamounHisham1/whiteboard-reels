# Whiteboard Reels — environment variables.
# Copy this file to .env (in your project root) and edit in your REAL keys.
# The scripts auto-load .env if present; real env vars take precedence. ~ is expanded to $HOME.
# This skill NEVER hardcodes secrets — you must provide your own keys.

# --- REQUIRED: mimo verification gate (no key = no verification) ---
# Get a token from opencode zen: https://opencode.ai/zen
OPENCODE_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- REQUIRED for Brian voice (falls back to Kokoro if unset, but Kokoro
#     only works if installed locally — see references/setup.md) ---
# Get a key from ElevenLabs (free tier = 10k chars/month): https://elevenlabs.io
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OPTIONAL ---
# ElevenLabs voice id. Default = Brian (nPczCjzI2devNBz1zQrb), a public preset voice.
# Override if your account can't access that voice.
# ELEVEN_VOICE=nPczCjzI2devNBz1zQrb

# --- OPTIONAL: Kokoro fallback (local, no API key) ---
# Install Kokoro first (see references/setup.md). There are two paths; set the vars
# for whichever you installed. Use a PERSISTENT directory (not /tmp).

# Path A: kokoro_onnx (lighter, int8 ONNX) — driven by scripts/tts_kokoro_onnx.py
# KOKORO_ONNX_MODEL=/path/to/kokoro-v1.0.int8.onnx
# KOKORO_ONNX_VOICES=/path/to/voices-v1.0.bin
# KOKORO_ONNX_VOICE=am_michael

# Path B: kokoro (KModel/KPipeline) — driven by scripts/tts.py's fallback
# KOKORO_PYTHON=/path/to/your/kokoro-python
# KOKORO_VOICE=am_michael

# Root containing per-slug folders (default <cwd>/videos)
# VIDEOS_DIR=/path/to/your/videos
